# PostgreSQL test database configuration
# Copy this file to .env and adjust as needed.
#
# To use PostgreSQL for Django tests (instead of the default SQLite):
#   1. Start the database: docker compose up -d
#   2. Copy this file: cp .env.EXAMPLE .env
#   3. Run tests: pytest tests/testapp/

DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=nplusone_test
DJANGO_DB_USER=nplusone
DJANGO_DB_PASSWORD=nplusone
DJANGO_DB_HOST=localhost
DJANGO_DB_PORT=5451
